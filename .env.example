APP_NAME="DecisionsRX RAG MVP"
CHROMA_PATH="data/chroma"
CHROMA_COLLECTION="decisionsrx"
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# LLM provider options: mock, openai
LLM_PROVIDER="mock"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_API_KEY=""

# Embedding provider options: hash (offline default/fallback), openai
EMBEDDING_PROVIDER="hash"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
